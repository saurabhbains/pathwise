# Server Configuration
PORT=3000
WS_PORT=3001

# LLM Provider Configuration
LLM_PROVIDER=gemini

# Comma-separated list of allowed browser origins for CORS.
# Keep localhost for development and add the deployed frontend URL for production.
ALLOWED_ORIGINS=http://localhost:5173,https://pathwise-ashy.vercel.app

# Claude API (if using Claude)
CLAUDE_API_KEY=

# Gemini API (if using Gemini)
GEMINI_API_KEY=

# Ollama Configuration (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Audio Configuration
WHISPER_MODEL_PATH=
PIPER_MODEL_PATH=

# Google Cloud TTS (for voice generation)
# Path to your Google Cloud service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=
